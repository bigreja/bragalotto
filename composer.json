{
  "name": "huseyinfiliz/pickem",
  "description": "Pick'em game extension for Flarum",
  "keywords": [
    "flarum",
    "extension",
    "pickem",
    "predictions",
    "sports"
  ],
  "type": "flarum-extension",
  "license": "MIT",
  "support": {
    "issues": "https://github.com/huseyinfiliz/pickem/issues",
    "source": "https://github.com/huseyinfiliz/pickem",
    "forum": "https://discuss.flarum.org/d/your-discussion-id" 
  },
  "homepage": "https://github.com/huseyinfiliz/pickem",
  "funding": [
    {
      "type": "website",
      "url": "https://github.com/huseyinfiliz"
    }
  ],
  "require": {
    "flarum/core": "^1.8.0"
  },
  "authors": [
    {
      "name": "Hüseyin Filiz",
      "email": "mysuperuser01@gmail.com",
      "role": "Developer"
    }
  ],
  "autoload": {
    "psr-4": {
      "huseyinfiliz\\Pickem\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "huseyinfiliz\\Pickem\\Tests\\": "tests/"
    }
  },
  "extra": {
    "flarum-extension": {
      "title": "Pick'em",
      "category": "feature",
      "icon": {
        "name": "fas fa-trophy",
        "backgroundColor": "#e74c3c",
        "color": "#fff"
      }
    }
  },
  "scripts": {
    "test": "phpunit -c phpunit.xml",
    "test:coverage": "phpunit -c phpunit.xml --coverage-html coverage",
    "analyse": "@php -r \"echo '⚠️  PHPStan disabled due to missing sockets extension.\\nTo enable: Install php-sockets extension on your server.\\nRunning tests only...\\n\\n';\"",
    "analyse:clear": "@php -r \"echo 'PHPStan cache clear skipped (PHPStan disabled)\\n';\"",
    "cs": [
      "@php -r \"if (!file_exists('vendor/bin/php-cs-fixer')) { echo '⚠️  php-cs-fixer not installed. Installing...\\n'; exit(0); }\"",
      "vendor/bin/php-cs-fixer fix --dry-run --diff"
    ],
    "cs:fix": [
      "@php -r \"if (!file_exists('vendor/bin/php-cs-fixer')) { echo '⚠️  php-cs-fixer not installed. Run: composer install\\n'; exit(1); }\"",
      "vendor/bin/php-cs-fixer fix"
    ],
    "qa": [
      "@test"
    ],
    "qa:full": [
      "@cs",
      "@test"
    ]
  },
  "scripts-descriptions": {
    "test": "Run unit tests",
    "test:coverage": "Run tests with code coverage",
    "analyse": "PHPStan disabled - requires php-sockets extension",
    "analyse:clear": "PHPStan cache clear (disabled)",
    "cs": "Check code style (requires php-cs-fixer)",
    "cs:fix": "Fix code style issues (requires php-cs-fixer)",
    "qa": "Run essential quality checks (Tests only - PHPStan disabled)",
    "qa:full": "Run all available quality checks (Code Style + Tests)"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "composer/installers": true
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "require-dev": {
    "flarum/phpstan": "*",
    "flarum/testing": "^1.0",
    "friendsofphp/php-cs-fixer": "^3.64"
  },
  "flagrow": {
    "discuss": "https://discuss.flarum.org/d/your-discussion-id"
  },
  "flarum-cli": {
    "modules": {
      "githubActions": true
    }
  }
}
